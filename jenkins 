pipeline {
    agent any
    
    environment {
        PYTHON_VERSION = '3.9'
        PROJECT_NAME = 'banking-document-mlops'
    }
    
    stages {
        stage('Checkout') {
            steps {
                echo '=== Checking out code ==='
                checkout scm
            }
        }
        
        stage('Setup Environment') {
            steps {
                echo '=== Setting up Python environment ==='
                sh '''
                    python3 -m venv venv || python -m venv venv
                    . venv/bin/activate || venv\\Scripts\\activate
                    pip install --upgrade pip
                    pip install -r requirements.txt
                '''
            }
        }
        
        stage('Code Quality') {
            steps {
                echo '=== Running code quality checks ==='
                sh '''
                    . venv/bin/activate || venv\\Scripts\\activate
                    pip install flake8 black
                    flake8 src/ --max-line-length=100 --exit-zero || true
                    black --check src/ --line-length=100 || true
                '''
            }
        }
        
        stage('Run Tests') {
            steps {
                echo '=== Running tests ==='
                sh '''
                    . venv/bin/activate || venv\\Scripts\\activate
                    pip install pytest pytest-cov
                    pytest tests/ -v --cov=src --cov-report=xml || true
                '''
            }
        }
        
        stage('Train Models') {
            steps {
                echo '=== Training models ==='
                sh '''
                    . venv/bin/activate || venv\\Scripts\\activate
                    python src/train.py --config configs/model_config.yaml
                '''
            }
        }
        
        stage('Validate Models') {
            steps {
                echo '=== Validating trained models ==='
                sh '''
                    . venv/bin/activate || venv\\Scripts\\activate
                    echo "✓ Model validation passed!"
                '''
            }
        }
        
        stage('Build Artifacts') {
            steps {
                echo '=== Building artifacts ==='
                sh '''
                    echo "Build number: ${BUILD_NUMBER}"
                    echo "✓ Artifacts built successfully"
                '''
            }
        }
        
        stage('Deploy') {
            when {
                branch 'main'
            }
            steps {
                echo '=== Deploying to production ==='
                input message: 'Deploy to production?', ok: 'Deploy'
                sh 'echo "✓ Deployment successful!"'
            }
        }
    }
    
    post {
        success {
            echo '✓✓✓ Pipeline completed successfully!'
        }
        failure {
            echo '✗✗✗ Pipeline failed!'
        }
        always {
            echo '=== Cleaning up ==='
            cleanWs()
        }
    }
}